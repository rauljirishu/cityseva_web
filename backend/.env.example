# MongoDB Atlas Configuration
# Get your MONGO_URI from MongoDB Atlas:
# 1. Go to https://cloud.mongodb.com
# 2. Create a cluster (free tier available)
# 3. Create a database user with read/write permissions
# 4. Copy the connection string and replace username:password with actual credentials
# 5. Add /cityseva at the end for database name
MONGO_URI=mongodb+srv://username:password@cluster0.mongodb.net/cityseva?retryWrites=true&w=majority

# Server Configuration
PORT=3000

# CORS Configuration (adjust for production)
CORS_ORIGIN=*

# Node Environment
NODE_ENV=development
